    <style>
      .user-mention[href$="/danimtb"] {
        color: var(--color-user-mention-fg);
        background-color: var(--bgColor-attention-muted, var(--color-attention-subtle));
        border-radius: 2px;
        margin-left: -2px;
        margin-right: -2px;
      }
      .user-mention[href$="/danimtb"]:before,
      .user-mention[href$="/danimtb"]:after {
        content: '';
        display: inline-block;
        width: 2px;
      }
    </style>


